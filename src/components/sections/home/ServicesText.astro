---
import { SERVICES } from "@/lib/data/services";
import { GameOfLife } from "@/components/react/GameOfLife";
import { cn } from "@/lib/utils";
---

<div class="relative w-full" data-reveal>
	{/* Mobile view */}
	<div class="mt-12 flex w-full flex-col items-start gap-14 tablet:hidden">
		<div class="flex w-full flex-col items-start gap-4">
			<span class="self-start text-[14px] font-medium leading-[20px] text-foreground">
				(02) SYSTEM SURFACES
			</span>
			<div class="flex w-full flex-row justify-between">
				<div class="flex flex-col gap-1">
					{
						SERVICES.map(({ label, active }) => (
							<p
								class={cn(
									"max-w-fit text-[28px] font-bold leading-[1.1] tracking-tight",
									active ? "text-foreground" : "text-muted-foreground/45",
								)}
							>
								{label}
							</p>
						))
					}
				</div>
				<div class="flex shrink-0 flex-col gap-1 pt-1">
					<p class="text-[14px] font-medium leading-[20px] text-foreground">Runtime safety</p>
					<p class="text-[14px] font-medium leading-[20px] text-foreground">Practice loops</p>
					<p class="text-[14px] font-medium leading-[20px] text-foreground">Creation flows</p>
				</div>
			</div>
		</div>
	</div>

	{/* Tablet/laptop view */}
	<div class="mt-24 hidden w-full flex-row items-start justify-between gap-16 overflow-visible tablet:flex">
		{/* Label + services list */}
		<div class="flex flex-col items-start gap-4">
			<span class="pl-0 font-mono text-[13px] uppercase leading-body-lg tracking-[0.18em] text-muted-foreground">
				(02) SYSTEM SURFACES
			</span>

			<div class="flex flex-col">
				{
					SERVICES.map(({ label, active }) => (
						<p
							class={cn(
								"font-medium leading-tight tracking-tight tablet:text-title-1 laptop:text-heading",
								active
									? "text-foreground"
									: "text-muted-foreground/50 dark:text-white/25",
							)}
						>
							{label}
						</p>
					))
				}
			</div>
		</div>

		{/* Game of Life + tag list */}
		<div class="flex shrink-0 flex-row items-end gap-10">
			<div class="flex flex-col gap-1 pb-2">
				<p class="text-body font-medium leading-body text-foreground">Runtime safety</p>
				<p class="text-body font-medium leading-body text-foreground">Practice loops</p>
				<p class="text-body font-medium leading-body text-foreground">Creation flows</p>
			</div>
			<div class="relative overflow-hidden rounded-lg bg-secondary tablet:aspect-[5/4] tablet:w-[320px] laptop:aspect-square laptop:w-[500px]">
				<GameOfLife client:visible className="absolute inset-0 block h-full w-full" />
			</div>
		</div>
	</div>
</div>
