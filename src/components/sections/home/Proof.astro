---
import { OSS_PROJECTS } from "@/lib/data/products";
import { OssCarousel } from "@/components/react/OssCarousel";

// Knowledge-graph motif: a deliberate node/edge layout (viewBox 480x360),
// not random - hub nodes (accent) carry the connected "built in the open" centre.
const gNodes = [
	{ x: 70, y: 78, r: 6 },
	{ x: 190, y: 48, r: 10, accent: true },
	{ x: 330, y: 86, r: 6 },
	{ x: 442, y: 158, r: 7 },
	{ x: 108, y: 188, r: 7 },
	{ x: 250, y: 168, r: 13, accent: true },
	{ x: 380, y: 242, r: 6 },
	{ x: 150, y: 312, r: 6 },
	{ x: 300, y: 322, r: 8, accent: true },
];
const gEdges = [
	[0, 1], [1, 2], [2, 3], [0, 4], [4, 5], [1, 5],
	[2, 5], [5, 6], [6, 3], [5, 8], [4, 7], [7, 8], [8, 6],
];
const gFlow = [[4, 5], [5, 6], [5, 8]];
const accents = gNodes.filter((n) => n.accent);
---

<section class="w-full bg-tile text-on-tile" data-reveal>
	<div class="mx-auto w-full max-w-site px-6 py-24 tablet:px-8 tablet:py-32">
		<div class="grid grid-cols-1 gap-12 laptop:grid-cols-[1fr_1fr] laptop:items-start laptop:gap-20">
			<div class="flex flex-col gap-6">
				<h2
					class="max-w-[14ch] font-display text-[clamp(1.875rem,3.5vw,3rem)] font-medium leading-[1.1] tracking-[-0.01em]"
				>
					Built in the open.
				</h2>
				<p class="max-w-[46ch] text-body-lg leading-[30px] text-on-tile/70">
					We partner when the work has a path to a real product or research
					system. The infrastructure behind that work lives on GitHub, not in a
					slide deck.
				</p>

				<svg
					class="gs-graph mt-4 w-full max-w-[480px] text-on-tile laptop:mt-2 laptop:flex-1"
					viewBox="0 0 480 360"
					fill="none"
					aria-hidden="true"
					preserveAspectRatio="xMidYMid meet"
				>
					{gEdges.map(([a, b]) => (
						<line class="gs-edge" x1={gNodes[a].x} y1={gNodes[a].y} x2={gNodes[b].x} y2={gNodes[b].y} />
					))}
					{gFlow.map(([a, b]) => (
						<line class="gs-flow" x1={gNodes[a].x} y1={gNodes[a].y} x2={gNodes[b].x} y2={gNodes[b].y} />
					))}
					{accents.map((n) => (
						<circle class="gs-halo" cx={n.x} cy={n.y} r={n.r + 8} />
					))}
					{gNodes.map((n, i) => (
						<circle
							class={n.accent ? "gs-node gs-accent" : "gs-node"}
							cx={n.x}
							cy={n.y}
							r={n.r}
							style={`animation-delay:${(i * 0.4).toFixed(2)}s`}
						/>
					))}
				</svg>
			</div>

			<OssCarousel client:visible projects={OSS_PROJECTS} />
		</div>
	</div>
</section>

<style>
	.gs-edge {
		stroke: currentColor;
		stroke-width: 1;
		opacity: 0.14;
	}
	.gs-node {
		fill: currentColor;
		animation: gs-pulse 4.5s ease-in-out infinite;
	}
	.gs-accent {
		fill: var(--color-signature);
	}
	.gs-halo {
		fill: var(--color-signature);
		opacity: 0.12;
	}
	.gs-flow {
		stroke: var(--color-signature);
		stroke-width: 1.5;
		stroke-dasharray: 3 7;
		animation: gs-flow 2.8s linear infinite;
	}
	@keyframes gs-pulse {
		0%, 100% { opacity: 0.45; }
		50% { opacity: 0.95; }
	}
	@keyframes gs-flow {
		to { stroke-dashoffset: -20; }
	}
	@media (prefers-reduced-motion: reduce) {
		.gs-node,
		.gs-flow {
			animation: none;
		}
		.gs-node { opacity: 0.8; }
	}
</style>
