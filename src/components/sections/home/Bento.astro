---
import { PRODUCT_LINES } from "@/lib/data/products";
import { AsciiField } from "@/components/react/AsciiField";
import { GameOfLife } from "@/components/react/GameOfLife";

const rustbox = PRODUCT_LINES.find((p) => p.id === "rustbox");
const booleanstack = PRODUCT_LINES.find((p) => p.id === "booleanstack");
const zen = PRODUCT_LINES.find((p) => p.id === "zen");
---

<section class="w-full px-4 tablet:px-6" data-reveal>
	<div class="mx-auto max-w-[96rem]">
		<div class="mb-6 flex flex-wrap items-baseline justify-between gap-2 tablet:mb-8">
			<p class="font-mono text-[13px] uppercase tracking-[0.18em] text-muted-foreground">
				(02) Product lines
			</p>
			<p class="font-mono text-[13px] uppercase tracking-[0.18em] text-muted-foreground">
				Secure execution / learning / interfaces
			</p>
		</div>

		<div class="grid grid-cols-2 gap-3 tablet:grid-cols-4 tablet:gap-3 laptop:auto-rows-[200px]">
			{/* Rustbox - hero tile, cobalt, live */}
			<a
				href={rustbox?.href}
				class="group relative col-span-2 row-span-2 flex min-h-[280px] cursor-pointer flex-col justify-between overflow-hidden rounded-[20px] bg-cobalt-500 p-7 text-paper-50 transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-[0_24px_48px_oklch(0.52_0.20_264_/_0.28)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2 focus-visible:ring-offset-background tablet:row-span-2 laptop:min-h-0"
			>
				<div class="flex items-center justify-between">
					<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-paper-50/80">
						Secure execution
					</span>
					<span class="inline-flex items-center gap-1.5 rounded-full bg-amber-500 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-ink-950">
						<span class="size-1.5 rounded-full bg-ink-950"></span>
						Live
					</span>
				</div>
				<div>
					<h3 class="text-[clamp(2.5rem,6vw,4.5rem)] font-black leading-[0.9] tracking-[-0.03em]">
						Rustbox
					</h3>
					<p class="mt-3 max-w-[34ch] text-body-lg leading-[28px] text-paper-50/85">
						{rustbox?.summary}
					</p>
				</div>
				<div class="flex items-center gap-2 font-mono text-[13px] uppercase tracking-[0.12em] text-paper-50">
					Open Rustbox
					<svg class="size-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
				</div>
			</a>

			{/* Living tile: three-body (navy) */}
			<div class="relative col-span-2 row-span-2 min-h-[280px] overflow-hidden rounded-[20px] bg-ink-950 laptop:min-h-0">
				<div class="absolute inset-0">
					<AsciiField client:visible />
				</div>
				<div class="pointer-events-none absolute inset-0 flex flex-col justify-between p-7">
					<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-paper-50/70">
						Systems in motion
					</span>
					<span class="font-mono text-[11px] uppercase tracking-[0.14em] text-paper-50/55">
						Figure-8 / three-body
					</span>
				</div>
			</div>

			{/* BooleanStack - amber tile */}
			<div class="group relative col-span-1 flex min-h-[200px] flex-col justify-between overflow-hidden rounded-[20px] bg-amber-500 p-6 text-ink-950 transition-transform duration-300 hover:-translate-y-1 tablet:col-span-2 laptop:min-h-0">
				<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-950/70">
					{booleanstack?.statusLabel}
				</span>
				<div>
					<h3 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-black leading-[0.95] tracking-[-0.03em]">
						BooleanStack
					</h3>
					<p class="mt-2 max-w-[30ch] text-base leading-[22px] text-ink-950/75">
						{booleanstack?.summary}
					</p>
				</div>
			</div>

			{/* Stat tile - paper */}
			<div class="col-span-1 flex min-h-[200px] flex-col justify-between rounded-[20px] border border-border bg-secondary p-6 laptop:min-h-0">
				<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">
					Shipping discipline
				</span>
				<div>
					<p class="text-[clamp(2.5rem,5vw,4rem)] font-black leading-none tracking-[-0.03em] text-foreground">
						1<span class="text-primary">/</span>3
					</p>
					<p class="mt-2 text-base leading-[22px] text-ink-700">
						products live. Two coming soon, no hype.
					</p>
				</div>
			</div>

			{/* Living tile: game of life (cobalt) */}
			<div class="relative col-span-1 min-h-[200px] overflow-hidden rounded-[20px] bg-cobalt-600 tablet:col-span-1 laptop:min-h-0">
				<div class="absolute inset-0">
					<GameOfLife client:visible />
				</div>
				<span class="pointer-events-none absolute bottom-5 left-6 font-mono text-[11px] uppercase tracking-[0.14em] text-paper-50/65">
					Emergent / alive
				</span>
			</div>

			{/* Zen - navy tile */}
			<div class="group relative col-span-1 flex min-h-[200px] flex-col justify-between overflow-hidden rounded-[20px] bg-ink-950 p-6 text-paper-50 transition-transform duration-300 hover:-translate-y-1 tablet:col-span-2 laptop:min-h-0">
				<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-paper-50/60">
					{zen?.statusLabel}
				</span>
				<div>
					<h3 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-black leading-[0.95] tracking-[-0.03em]">
						Zen
					</h3>
					<p class="mt-2 max-w-[30ch] text-base leading-[22px] text-paper-50/70">
						{zen?.summary}
					</p>
				</div>
				<span class="absolute right-6 top-6 size-2 rounded-full bg-amber-500"></span>
			</div>
		</div>
	</div>
</section>
