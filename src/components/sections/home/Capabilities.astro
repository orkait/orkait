---
import { MemoryGraph } from "@/components/react/MemoryGraph";
// The dark "open and under the hood" beat. GraphStore + Hyperstack are open
// source, Orka is research. No invented metrics. The product lines live in the
// Bento section, not here, so nothing repeats across the page.
type Metric = { value: string; label: string };
type Capability = {
	name: string;
	surface: string;
	status: "Open source" | "Research";
	href?: string;
	cta?: string;
	statement: string;
	detail: string;
	metrics: Metric[];
};

const capabilities: Capability[] = [
	{
		name: "GraphStore",
		surface: "Agent memory",
		status: "Open source",
		href: "https://github.com/orkait/graphstore",
		cta: "View on GitHub",
		statement: "Agent memory that recalls by meaning, not keywords.",
		detail:
			"Six engines behind one readable DSL: columnar numpy storage, HNSW vector search, and a markdown vault built for 24/7 agents.",
		metrics: [
			{ value: "6", label: "engines" },
			{ value: "~127µs", label: "semantic recall" },
			{ value: "Python", label: "library" },
		],
	},
	{
		name: "Hyperstack",
		surface: "Engineering harness",
		status: "Open source",
		href: "https://github.com/orkait/hyperstack",
		cta: "View on GitHub",
		statement: "Stop AI agents from shipping plausible-but-wrong code.",
		detail:
			"Real-time ground truth for React, Next.js, Motion, React Flow, Echo, Go, Rust, and design tokens, enforced by adversarial gates.",
		metrics: [
			{ value: "21", label: "skill gates" },
			{ value: "10+", label: "stacks covered" },
		],
	},
	{
		name: "Orka",
		surface: "Model compression",
		status: "Research",
		statement: "Language-model weights, compressed toward 1 bit.",
		detail:
			"Learned codebooks and a hand-written GGML kernel keep reconstruction byte-exact.",
		metrics: [{ value: "~1 bit", label: "per-weight target" }],
	},
];

const statusClass: Record<Capability["status"], string> = {
	"Open source": "border border-on-tile/30 text-on-tile",
	Research: "border border-on-tile/15 text-on-tile/70",
};
---

<section class="w-full bg-tile text-on-tile py-20 tablet:py-28 laptop:py-32">
	<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
		<div class="grid grid-cols-1 gap-12 laptop:grid-cols-[5fr_7fr] laptop:gap-20">
			<div class="flex flex-col gap-6 laptop:sticky laptop:top-28 laptop:self-start">
				<p class="font-mono text-[12px] uppercase tracking-[0.18em] text-on-tile/55">
					Open and under the hood
				</p>
				<h2
					class="max-w-[16ch] font-display text-[clamp(1.875rem,3.5vw,3rem)] font-medium leading-[1.1] tracking-[-0.01em]"
				>
					We wrote the hard parts ourselves.
				</h2>
				<p class="max-w-[44ch] text-body-lg leading-[30px] text-on-tile/70">
					GraphStore and Hyperstack are open source. Orka compresses model
					weights toward 1 bit. Read the code, run the tests.
				</p>

				<MemoryGraph
					client:visible
					tone="dark"
					className="mt-6 hidden h-[clamp(280px,32vh,360px)] w-full laptop:block"
				/>
			</div>

			<ul class="flex flex-col gap-4 tablet:gap-5">
				{
					capabilities.map((c) => (
						<li data-reveal>
							<article class="group flex flex-col gap-5 rounded-[20px] border border-on-tile/15 bg-on-tile/[0.04] p-8 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-on-tile/30 tablet:p-10">
								<div class="flex items-center justify-between gap-3">
									<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-on-tile/55">
										{c.surface}
									</span>
									<span
										class={`rounded-full px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.14em] ${statusClass[c.status]}`}
									>
										{c.status}
									</span>
								</div>

								<div class="flex flex-col gap-2.5">
									<h3 class="font-display text-[clamp(1.625rem,2.6vw,2.25rem)] font-medium leading-[1.05] tracking-[-0.015em]">
										{c.name}
									</h3>
									<p class="max-w-[46ch] text-body-lg leading-[28px] text-on-tile">
										{c.statement}
									</p>
									<p class="max-w-[52ch] text-base leading-[24px] text-on-tile/65">
										{c.detail}
									</p>
								</div>

								{c.metrics.length > 0 && (
									<dl class="mt-1 flex flex-wrap gap-x-10 gap-y-4 border-t border-on-tile/12 pt-5">
										{c.metrics.map((m) => (
											<div class="flex flex-col gap-0.5">
												<dt class="order-2 font-mono text-[11px] uppercase tracking-[0.12em] text-on-tile/55">
													{m.label}
												</dt>
												<dd class="order-1 text-[clamp(1.5rem,2.2vw,2rem)] font-black leading-none tracking-[-0.02em] text-signature tabular-nums">
													{m.value}
												</dd>
											</div>
										))}
									</dl>
								)}

								{c.href && (
									<a
										href={c.href}
										target="_blank"
										rel="noopener noreferrer"
										class="mt-1 inline-flex w-fit items-center gap-2 font-mono text-[13px] font-bold uppercase tracking-[0.12em] text-on-tile transition-colors hover:text-signature focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-on-tile focus-visible:ring-offset-2 focus-visible:ring-offset-tile"
									>
										{c.cta}
										<svg
											class="size-4 transition-transform duration-200 group-hover:translate-x-1"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M5 12h14M13 6l6 6-6 6" />
										</svg>
									</a>
								)}
							</article>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
