---
// Real, verifiable capability substance sourced from the product repos.
// Honest: Rustbox is live, GraphStore + Hyperstack are open source, Zen +
// BooleanStack are coming soon. No invented metrics.
type Metric = { value: string; label: string };
type Capability = {
	name: string;
	surface: string;
	status: "Live" | "Open source" | "Coming soon";
	href?: string;
	cta?: string;
	statement: string;
	detail?: string;
	metrics: Metric[];
	emphasis?: boolean;
};

const capabilities: Capability[] = [
	{
		name: "Rustbox",
		surface: "Secure execution",
		status: "Live",
		href: "https://rustbox.orkait.com",
		cta: "Open Rustbox",
		statement: "A kernel-enforced sandbox for running untrusted code.",
		detail:
			"seccomp-bpf syscall filtering, Linux namespaces, and cgroups v2 with deterministic resource limits. Single binary, no Docker daemon.",
		metrics: [
			{ value: "8", label: "languages" },
			{ value: "147", label: "adversarial exploits" },
			{ value: "0", label: "sandbox escapes" },
		],
		emphasis: true,
	},
	{
		name: "GraphStore",
		surface: "Agent memory",
		status: "Open source",
		href: "https://github.com/orkait/graphstore",
		cta: "View on GitHub",
		statement: "Recall by meaning or association, ingest documents, track beliefs.",
		detail:
			"Six engines behind one readable DSL: columnar numpy storage, HNSW vector search, and a markdown vault built for 24/7 agents.",
		metrics: [
			{ value: "6", label: "engines" },
			{ value: "~127µs", label: "semantic recall" },
			{ value: "Python", label: "library" },
		],
	},
	{
		name: "Hyperstack",
		surface: "Engineering harness",
		status: "Open source",
		href: "https://github.com/orkait/hyperstack",
		cta: "View on GitHub",
		statement: "An MCP server and skill gates that keep AI agents honest.",
		detail:
			"Real-time ground truth for React, Next.js, Motion, React Flow, Echo, Go, Rust, and design tokens, enforced by adversarial gates.",
		metrics: [
			{ value: "21", label: "skill gates" },
			{ value: "10+", label: "stacks covered" },
		],
	},
	{
		name: "Zen",
		surface: "Interface creation",
		status: "Coming soon",
		statement: "Turn a prompt into interactive multi-screen UI.",
		detail: "Rough product intent becomes usable, collaborative screens.",
		metrics: [],
	},
	{
		name: "BooleanStack",
		surface: "Software learning",
		status: "Coming soon",
		statement: "Serious practice that rewards depth, not streaks.",
		detail: "Data structures, algorithms, and system design for real engineering.",
		metrics: [],
	},
];

const statusClass: Record<Capability["status"], string> = {
	Live: "bg-signature-deep text-on-signature",
	"Open source": "border border-foreground/25 text-foreground",
	"Coming soon": "border border-border text-muted-foreground",
};
---

<section class="w-full py-20 tablet:py-28 laptop:py-32">
	<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
		<div class="grid grid-cols-1 gap-12 laptop:grid-cols-[5fr_7fr] laptop:gap-20">
			<div class="flex flex-col gap-6 laptop:sticky laptop:top-28 laptop:self-start">
				<p class="font-mono text-[12px] uppercase tracking-[0.18em] text-muted-foreground">
					What we actually ship
				</p>
				<h2
					class="max-w-[15ch] font-display text-[clamp(1.875rem,3.5vw,3rem)] font-medium leading-[1.1] tracking-[-0.01em] text-foreground"
				>
					Measured, shipped, and open.
				</h2>
				<p class="max-w-[42ch] text-body-lg leading-[30px] text-ink-700">
					Not a roadmap. Rustbox runs untrusted code under kernel isolation
					today, GraphStore and Hyperstack are open source, and the proof is
					public.
				</p>

				<svg
					class="cap-flow mt-6 hidden w-[200px] text-foreground laptop:block"
					viewBox="0 0 200 300"
					fill="none"
					aria-hidden="true"
				>
					<line class="cap-edge" x1="30" y1="34" x2="100" y2="160"></line>
					<line class="cap-edge" x1="74" y1="24" x2="100" y2="160"></line>
					<line class="cap-edge" x1="118" y1="32" x2="100" y2="160"></line>
					<line class="cap-edge" x1="162" y1="26" x2="100" y2="160"></line>
					<line class="cap-edge" x1="52" y1="58" x2="100" y2="160"></line>
					<line class="cap-edge" x1="140" y1="56" x2="100" y2="160"></line>
					<line class="cap-ship" x1="100" y1="160" x2="100" y2="262"></line>
					<circle class="cap-in" cx="30" cy="34" r="4"></circle>
					<circle class="cap-in" cx="74" cy="24" r="4"></circle>
					<circle class="cap-in" cx="118" cy="32" r="4"></circle>
					<circle class="cap-in" cx="162" cy="26" r="4"></circle>
					<circle class="cap-in" cx="52" cy="58" r="4"></circle>
					<circle class="cap-in" cx="140" cy="56" r="4"></circle>
					<circle class="cap-gate" cx="100" cy="160" r="6"></circle>
					<circle class="cap-halo" cx="100" cy="262" r="16"></circle>
					<circle class="cap-end" cx="100" cy="262" r="8"></circle>
				</svg>
			</div>

			<ul class="flex flex-col gap-4 tablet:gap-5">
				{
					capabilities.map((c) => (
						<li data-reveal>
							<article
								class={`group flex flex-col gap-5 rounded-[20px] border p-8 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 tablet:p-10 ${
									c.emphasis
										? "border-signature/40 bg-signature-soft/40 hover:border-signature/60"
										: "border-border bg-secondary hover:border-foreground/20 hover:shadow-[0_18px_44px_oklch(0.20_0.02_265_/_0.07)]"
								}`}
							>
								<div class="flex items-center justify-between gap-3">
									<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">
										{c.surface}
									</span>
									<span
										class={`rounded-full px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.14em] ${statusClass[c.status]}`}
									>
										{c.status}
									</span>
								</div>

								<div class="flex flex-col gap-2.5">
									<h3 class="font-display text-[clamp(1.625rem,2.6vw,2.25rem)] font-medium leading-[1.05] tracking-[-0.015em] text-foreground">
										{c.name}
									</h3>
									<p class="max-w-[46ch] text-body-lg leading-[28px] text-foreground">
										{c.statement}
									</p>
									{c.detail && (
										<p class="max-w-[52ch] text-base leading-[24px] text-ink-700">
											{c.detail}
										</p>
									)}
								</div>

								{c.metrics.length > 0 && (
									<dl class="mt-1 flex flex-wrap gap-x-10 gap-y-4 border-t border-foreground/10 pt-5">
										{c.metrics.map((m) => (
											<div class="flex flex-col gap-0.5">
												<dt class="order-2 font-mono text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
													{m.label}
												</dt>
												<dd class="order-1 text-[clamp(1.5rem,2.2vw,2rem)] font-black leading-none tracking-[-0.02em] text-signature-deep tabular-nums">
													{m.value}
												</dd>
											</div>
										))}
									</dl>
								)}

								{c.href && (
									<a
										href={c.href}
										target="_blank"
										rel="noopener noreferrer"
										class="mt-1 inline-flex w-fit items-center gap-2 font-mono text-[13px] font-bold uppercase tracking-[0.12em] text-foreground transition-colors hover:text-signature-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
									>
										{c.cta}
										<svg
											class="size-4 transition-transform duration-200 group-hover:translate-x-1"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M5 12h14M13 6l6 6-6 6"></path>
										</svg>
									</a>
								)}
							</article>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<style>
	.cap-edge {
		stroke: currentColor;
		stroke-width: 1;
		opacity: 0.14;
	}
	.cap-in {
		fill: currentColor;
		opacity: 0.28;
	}
	.cap-gate {
		fill: currentColor;
		opacity: 0.5;
	}
	.cap-ship {
		stroke: var(--color-signature-deep);
		stroke-width: 2;
		stroke-dasharray: 3 6;
		animation: cap-ship 2.6s linear infinite;
	}
	.cap-end {
		fill: var(--color-signature-deep);
	}
	.cap-halo {
		fill: var(--color-signature-deep);
		opacity: 0.12;
	}
	@keyframes cap-ship {
		to {
			stroke-dashoffset: -18;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.cap-ship {
			animation: none;
		}
	}
</style>
