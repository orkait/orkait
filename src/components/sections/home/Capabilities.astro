---
import { FEATURES } from "@/lib/data/features";

// Strip the legacy "(0x)" wrappers; render clean ordinals in the signature accent.
const items = FEATURES.map((f, i) => ({
	n: String(i + 1).padStart(2, "0"),
	title: f.title,
	description: f.description,
}));

// Group into clusters so dividers stay sparse (one hairline between groups,
// none between rows inside a group).
const clusters = [items.slice(0, 3), items.slice(3, 5), items.slice(5)];
---

<section class="w-full py-20 tablet:py-28 laptop:py-32" data-reveal>
	<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
		<div class="grid grid-cols-1 gap-12 laptop:grid-cols-[5fr_7fr] laptop:gap-20">
			<div class="flex flex-col gap-6 laptop:sticky laptop:top-28 laptop:self-start">
				<p
					class="font-mono text-[12px] uppercase tracking-[0.18em] text-muted-foreground"
				>
					How the lab decides what ships
				</p>
				<h2
					class="max-w-[16ch] font-display text-[clamp(1.875rem,3.5vw,3rem)] font-medium leading-[1.1] tracking-[-0.01em] text-foreground"
				>
					Research only counts when it survives production.
				</h2>
				<p class="max-w-[42ch] text-body-lg leading-[30px] text-ink-700">
					A short set of rules keeps the work honest: every direction maps to a
					real product surface, and nothing gets called live until people can use
					it.
				</p>

				<svg
					class="cap-flow mt-6 hidden w-[200px] text-foreground laptop:block"
					viewBox="0 0 200 300"
					fill="none"
					aria-hidden="true"
				>
					<line class="cap-edge" x1="30" y1="34" x2="100" y2="160"></line>
					<line class="cap-edge" x1="74" y1="24" x2="100" y2="160"></line>
					<line class="cap-edge" x1="118" y1="32" x2="100" y2="160"></line>
					<line class="cap-edge" x1="162" y1="26" x2="100" y2="160"></line>
					<line class="cap-edge" x1="52" y1="58" x2="100" y2="160"></line>
					<line class="cap-edge" x1="140" y1="56" x2="100" y2="160"></line>
					<line class="cap-ship" x1="100" y1="160" x2="100" y2="262"></line>
					<circle class="cap-in" cx="30" cy="34" r="4"></circle>
					<circle class="cap-in" cx="74" cy="24" r="4"></circle>
					<circle class="cap-in" cx="118" cy="32" r="4"></circle>
					<circle class="cap-in" cx="162" cy="26" r="4"></circle>
					<circle class="cap-in" cx="52" cy="58" r="4"></circle>
					<circle class="cap-in" cx="140" cy="56" r="4"></circle>
					<circle class="cap-gate" cx="100" cy="160" r="6"></circle>
					<circle class="cap-halo" cx="100" cy="262" r="16"></circle>
					<circle class="cap-end" cx="100" cy="262" r="8"></circle>
				</svg>
			</div>

			<div class="flex flex-col gap-12">
				{
					clusters.map((cluster, ci) => (
						<div
							class={ci === 0 ? "" : "border-t border-border pt-12"}
						>
							<ul class="flex flex-col gap-7">
								{cluster.map((f) => (
									<li class="grid grid-cols-[auto_1fr] items-baseline gap-x-5 tablet:gap-x-7">
										<span class="font-mono text-[15px] font-bold text-signature-deep tabular-nums">
											{f.n}
										</span>
										<div class="flex flex-col gap-1.5">
											<h3 class="text-[19px] font-bold leading-tight tracking-tight text-foreground tablet:text-subtitle">
												{f.title}
											</h3>
											<p class="max-w-[52ch] text-base leading-[24px] text-ink-700">
												{f.description}
											</p>
										</div>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.cap-edge {
		stroke: currentColor;
		stroke-width: 1;
		opacity: 0.14;
	}
	.cap-in {
		fill: currentColor;
		opacity: 0.28;
	}
	.cap-gate {
		fill: currentColor;
		opacity: 0.5;
	}
	.cap-ship {
		stroke: var(--color-signature-deep);
		stroke-width: 2;
		stroke-dasharray: 3 6;
		animation: cap-ship 2.6s linear infinite;
	}
	.cap-end {
		fill: var(--color-signature-deep);
	}
	.cap-halo {
		fill: var(--color-signature-deep);
		opacity: 0.12;
	}
	@keyframes cap-ship {
		to { stroke-dashoffset: -18; }
	}
	@media (prefers-reduced-motion: reduce) {
		.cap-ship { animation: none; }
	}
</style>
