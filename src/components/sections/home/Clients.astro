---
import LogoWall from "@/components/ui/LogoWall.astro";
import { CLIENTS } from "@/lib/data/clients";
---

{
	CLIENTS.length > 0 && (
		<section class="w-full py-10 tablet:py-12" data-reveal>
			<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
				<p class="mb-8 text-center font-mono text-[12px] uppercase tracking-[0.18em] text-muted-foreground tablet:mb-10">
					Trusted by teams at
				</p>
				<LogoWall clients={CLIENTS} />
			</div>
		</section>
	)
}
