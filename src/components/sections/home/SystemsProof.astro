---
import { SYSTEMS_PROOF_INTRO, PROOF_POINTS } from "@/lib/data/proof-points";
---

<section class="w-full py-20 tablet:py-28 laptop:py-32" data-reveal>
	<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
		<div class="flex max-w-[44ch] flex-col gap-5">
			<p class="font-mono text-[12px] uppercase tracking-[0.18em] text-muted-foreground">
				{SYSTEMS_PROOF_INTRO.eyebrow}
			</p>
			<h2
				class="font-display text-[clamp(1.875rem,3.5vw,3rem)] font-medium leading-[1.1] tracking-[-0.01em] text-foreground"
			>
				{SYSTEMS_PROOF_INTRO.title}
			</h2>
			<p class="text-body-lg leading-[30px] text-ink-700">
				{SYSTEMS_PROOF_INTRO.lead}
			</p>
		</div>

		<div
			class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-[18px] border border-border bg-border tablet:mt-16 tablet:grid-cols-2 laptop:grid-cols-4"
		>
			{
				PROOF_POINTS.map((point) => (
					<div class="flex flex-col gap-3 bg-background p-6 tablet:p-7">
						<p class="font-mono text-[11px] uppercase tracking-[0.14em] text-signature-deep">
							{point.label}
						</p>
						<p class="font-display text-[20px] font-medium leading-[1.15] tracking-[-0.01em] text-foreground">
							{point.claim}
						</p>
						<p class="text-base leading-[24px] text-ink-700">{point.detail}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
