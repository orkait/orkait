---
import { FEATURES } from "@/lib/data/features";
import { cn } from "@/lib/utils";

const cardClass = (index: number) =>
	cn(
		"flex flex-col py-6 tablet:gap-2 tablet:py-10 border-border tablet:border-b",
		index % 2 === 0 && index !== 6 && "pr-[16px] border-r border-[#e8e8e8] dark:border-white/10 tablet:border-r-0 tablet:pr-0",
		index % 2 !== 0 && index !== 6 && "pl-[16px] tablet:pl-0",
		index === 6 && "col-span-2 w-full mx-auto tablet:col-span-1 tablet:w-full tablet:mx-0",
		index < 6 && "border-b border-[#e8e8e8] dark:border-white/10 tablet:border-border",
	);
---

<section class="mt-12 tablet:mt-12 base:mt-24" data-reveal>
	{/* Mobile Title */}
	<div class="mb-10 w-full tablet:hidden">
		<h2 class="flex flex-col text-[24px] font-bold leading-[30px] tracking-tight text-foreground">
			<span>How the lab</span>
			<span>decides what ships</span>
		</h2>
	</div>

	<div class="grid grid-cols-2 gap-y-0 tablet:grid-cols-2 tablet:gap-x-16 laptop:grid-cols-3">
		{
			FEATURES.map((f, i) => (
				<div class={cardClass(i)}>
					<div class="mb-[8px] flex flex-row items-center gap-[6px] tablet:mb-0 tablet:flex-col tablet:items-start tablet:gap-0">
						<p class="text-[14px] font-medium leading-[20px] text-[#111] tablet:text-subtitle tablet:leading-subtitle tablet:text-muted-foreground dark:text-[#eee]">
							{f.num}
						</p>
						<p class="text-[15px] font-bold leading-[22px] text-[#111] tablet:text-subtitle tablet:font-medium tablet:leading-subtitle tablet:text-foreground dark:text-[#eee]">
							{f.title}
						</p>
					</div>
					<p class="text-[12px] font-normal leading-[18px] text-[#6d6d6d] tablet:text-body tablet:leading-body tablet:text-muted-foreground dark:text-[#a0a0a0]">
						{f.description}
					</p>
				</div>
			))
		}

		{/* Tagline (Tablet & Desktop) */}
		<div
			class="col-span-1 mt-12 hidden items-center tablet:col-span-2 tablet:flex laptop:col-start-3 laptop:row-span-2 laptop:row-start-1 laptop:mt-0"
		>
			<h2 class="text-heading font-bold leading-heading tracking-tight text-foreground">
				How the lab decides what ships
			</h2>
		</div>
	</div>
</section>
