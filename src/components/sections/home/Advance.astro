---
import { CAPABILITIES_LEFT, CAPABILITIES_RIGHT } from "@/lib/data/capabilities";
---

<div
	class="relative mt-12 flex flex-col overflow-x-clip base:mt-24 tablet:min-h-[400px] tablet:justify-between laptop:min-h-[800px]"
	data-reveal
>
	{/* Desktop decorative stripe pattern */}
	<div class="pointer-events-none absolute inset-y-0 right-0 hidden h-full w-[35vw] max-w-[32rem] items-center justify-end overflow-hidden tablet:flex">
		<img
			src="/data/homepage/graphic-container.svg"
			alt=""
			class="absolute inset-0 h-full w-full object-contain object-right"
			aria-hidden="true"
		/>
		<div class="absolute inset-0 bg-white/10" aria-hidden="true"></div>
	</div>

	{/* Main content */}
	<div class="relative flex max-w-full flex-col gap-10 tablet:gap-16 laptop:max-w-[80%] base:max-w-[60%]">
		{/* Mobile Section label, top */}
		<p class="text-[14px] font-medium leading-[20px] text-foreground tablet:hidden">(03) DISCIPLINE</p>

		<h2 class="max-w-[12ch] text-[24px] font-medium leading-[30px] tracking-tight text-foreground tablet:hidden">
			Research only matters when it survives production.
		</h2>

		{/* Heading (Hidden on Mobile) */}
		<h2 class="hidden text-title-1 font-medium leading-title-1 tracking-tight text-foreground tablet:block tablet:text-heading tablet:leading-heading">
			Research only matters when it survives production.
		</h2>

		{/* Features container */}
		<div class="relative w-full">
			{/* Mobile decorative stripe pattern */}
			<div class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 tablet:hidden">
				<div class="relative h-[220px] w-[168px]">
					<img
						src="/data/homepage/graphic-container.svg"
						alt=""
						class="absolute inset-0 h-full w-full object-contain object-right"
						aria-hidden="true"
					/>
					<div class="absolute inset-0 bg-white/10" aria-hidden="true"></div>
				</div>
			</div>

			{/* Capability list */}
			<div class="relative z-10 grid w-[82%] grid-cols-1 gap-x-16 gap-y-4 tablet:w-full tablet:grid-cols-2 tablet:gap-y-6">
				<div class="flex flex-col gap-4 tablet:gap-6">
					{
						CAPABILITIES_LEFT.map((item) => (
							<div class="flex h-[34px] flex-col justify-center tablet:h-auto">
								<p class="text-[14px] font-medium leading-[20px] text-foreground tablet:text-subtitle tablet:leading-subtitle">
									{item}
								</p>
							</div>
						))
					}
				</div>
				<div class="flex flex-col gap-4 tablet:gap-6">
					{
						CAPABILITIES_RIGHT.map((item) => (
							<div class="flex h-[34px] flex-col justify-center tablet:h-auto">
								<p class="text-[14px] font-medium leading-[20px] text-foreground tablet:text-subtitle tablet:leading-subtitle">
									{item}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>

	{/* Section label, bottom (Hidden on Mobile) */}
	<p class="mt-12 hidden text-body-lg font-medium leading-body-lg text-foreground tablet:block">
		(03) DISCIPLINE
	</p>
</div>
