---
import { routes } from "@/config/routes";
import { AsciiField } from "@/components/react/AsciiField";
---

<div class="relative w-full overflow-visible" data-reveal>
	{/* Mobile view */}
	<div class="mt-12 flex w-full flex-col items-start tablet:hidden">
		<div class="w-full">
			<span class="float-left mr-4 pt-1">
				<p class="text-body font-medium uppercase leading-none tracking-widest text-muted-foreground">
					(01) Lab Thesis
				</p>
			</span>
			<h2 class="text-subtitle font-medium leading-tight tracking-tight text-foreground">
				We build where execution, learning, and interface work need real product discipline.
			</h2>
		</div>

		<div class="mt-14 flex w-full flex-col items-start gap-8">
			<div class="relative aspect-[340/220] max-h-[220px] w-full shrink-0 overflow-hidden rounded-lg bg-[#fafafa]">
				<AsciiField client:visible />
			</div>

			<div class="flex w-full flex-col gap-7">
				<p class="max-w-[34ch] text-[14px] font-medium leading-[22px] text-foreground">
					Orkait is product-first. We move from research questions into systems that can be
					used, measured, and maintained.
				</p>

				<div class="flex flex-col items-start gap-6">
					<p class="max-w-[34ch] text-[14px] font-medium leading-[22px] text-foreground">
						We keep the lab small on purpose. Research earns space here when it can become a
						working system.
					</p>
					<a
						href={routes.projects}
						class="inline-flex h-auto items-center justify-center rounded-md bg-foreground px-4 py-2 text-[14px] font-medium text-white transition-colors hover:bg-foreground/90"
					>
						View Products
					</a>
				</div>
			</div>
		</div>
	</div>

	{/* Tablet/laptop view */}
	<div class="mt-12 hidden w-full flex-col items-start base:mt-24 tablet:flex">
		<div class="block w-full">
			<div class="float-left mb-4 tablet:mb-0 tablet:w-[150px] laptop:w-[200px]">
				<p class="pt-2 text-body font-medium uppercase leading-none tracking-widest text-muted-foreground tablet:leading-body">
					(01) Lab Thesis
				</p>
			</div>
			<h2 class="block max-w-[1400px] text-subtitle font-medium leading-tight tracking-tight text-foreground tablet:text-title-1 tablet:leading-title-1 laptop:text-heading laptop:leading-heading">
				We build where execution, learning, and interface work need real product discipline.
			</h2>
		</div>

		<div class="clear-both"></div>

		<div class="mt-12 grid w-full grid-cols-1 items-start gap-8 tablet:grid-cols-1 laptop:mt-24 laptop:grid-cols-3 laptop:gap-8 base:gap-12">
			{/* Image column */}
			<div class="relative aspect-[340/375] w-full shrink-0 overflow-hidden rounded-lg bg-[#fafafa] laptop:aspect-[291/322]">
				<AsciiField client:visible />
			</div>

			<div class="laptop:ml-24 laptop:max-w-[311px]">
				<p class="text-[14px] font-medium leading-[20px] text-foreground tablet:text-body tablet:leading-body laptop:text-body-lg laptop:leading-body-lg">
					Orkait is product-first. We move from research questions into systems that can be
					used, measured, and maintained.
				</p>
			</div>

			{/* Second description + CTA */}
			<div class="flex flex-col items-start gap-8 laptop:max-w-[280px]">
				<p class="text-[14px] font-medium leading-[20px] text-foreground tablet:text-body tablet:leading-body laptop:text-body-lg laptop:leading-body-lg">
					We keep the lab small on purpose. Research earns space here when it can become a
					working system.
				</p>
				<a
					href={routes.projects}
					class="inline-flex h-auto items-center justify-center rounded-md bg-black px-4 py-2 text-[14px] font-medium text-white transition-colors hover:bg-black/90 tablet:text-base"
				>
					View Products
				</a>
			</div>
		</div>
	</div>
</div>
