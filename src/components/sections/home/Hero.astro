---
import { routes } from "@/lib/data/nav";
import { SplitHeadline } from "@/components/react/SplitHeadline";
import { MagneticButton } from "@/components/react/MagneticButton";
import { HeroVisual } from "@/components/react/HeroVisual";

const rustboxHref = "https://rustbox.orkait.com";

const headlineLines = [
	[{ t: "Applied" }, { t: "AI" }, { t: "research," }],
	[{ t: "shipped" }, { t: "as" }, { t: "products.", accent: true }],
];

const ticker = [
	"Rustbox - live",
	"BooleanStack - soon",
	"Zen - soon",
	"Secure execution",
	"Software learning",
	"Interface creation",
];
const loop = [...ticker, ...ticker];
---

<section
	aria-label="Intro"
	class="w-full pt-12 pb-20 tablet:pt-16 tablet:pb-28"
	data-reveal
>
	<div class="mx-auto w-full max-w-site px-6 tablet:px-8">
		<div class="mx-auto flex max-w-[68rem] flex-col items-center gap-7 text-center tablet:gap-8">
			<p class="font-mono text-[12px] uppercase tracking-[0.18em] text-muted-foreground">
				Product-first AI lab
			</p>

			<SplitHeadline
				client:load
				lines={headlineLines}
				className="text-foreground"
				style={{
					fontWeight: 900,
					letterSpacing: "-0.035em",
					lineHeight: 0.95,
					fontSize: "clamp(2.75rem, 7vw, 6rem)",
				}}
			/>

			<p class="max-w-[48ch] text-body-lg leading-[30px] text-ink-700">
				Focused tools for secure execution, software learning, and AI-assisted
				creation. Rustbox is live.
			</p>

			<div class="flex flex-col gap-3 pt-1 tablet:flex-row tablet:items-center">
				<MagneticButton
					client:visible
					href={rustboxHref}
					className="group inline-flex h-12 min-h-[44px] cursor-pointer items-center justify-center gap-2 rounded-lg bg-primary px-7 text-base font-bold text-primary-foreground shadow-[0_8px_24px_oklch(0.20_0.02_265_/_0.14)] transition-[background-color] duration-200 hover:bg-signature-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
				>
					Open Rustbox
					<svg
						class="size-[18px] transition-transform duration-200 group-hover:translate-x-0.5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14M13 6l6 6-6 6"></path>
					</svg>
				</MagneticButton>

				<MagneticButton
					client:visible
					href={routes.projects}
					strength={0.25}
					className="inline-flex h-12 min-h-[44px] cursor-pointer items-center justify-center gap-2 rounded-lg border border-foreground/20 bg-transparent px-7 text-base font-semibold text-foreground transition-colors duration-200 hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
				>
					Products &amp; Team
				</MagneticButton>
			</div>
		</div>

		<div class="mt-14 w-full tablet:mt-16">
			<HeroVisual
				client:visible
				eyebrow="Secure execution / systems in motion"
				statement="Untrusted code, run under real constraints."
			/>
		</div>

		<div
			class="mt-14 w-full overflow-hidden rounded-[20px] bg-signature-deep py-4 text-on-signature tablet:mt-16"
			aria-hidden="true"
		>
			<div class="marquee-track gap-0">
				{
					loop.map((t) => (
						<span class="flex items-center whitespace-nowrap px-8 font-mono text-[13px] uppercase tracking-[0.18em]">
							{t}
							<span class="ml-8 opacity-40">/</span>
						</span>
					))
				}
			</div>
		</div>
	</div>
</section>
