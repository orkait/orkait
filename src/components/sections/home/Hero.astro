---
import { routes } from "@/lib/data/nav";
---

<div class="relative w-full overflow-visible" data-reveal>
	{/* Mobile view */}
	<div class="flex flex-col gap-14 pt-4 pb-4 tablet:hidden">
		<div class="flex w-full justify-end">
			<div class="flex w-full max-w-[320px] flex-col items-end gap-8">
				<span class="w-full max-w-[320px] text-wrap text-right text-[22px] font-medium leading-[24px] tracking-[-0.04em] text-foreground">
					We engineer software that works. Honest engineering. Reliable systems. No hype.
				</span>
				<a
					href={routes.projects}
					class="inline-flex h-auto items-center justify-center gap-[10px] rounded-md bg-foreground px-4 py-2 text-base font-normal text-white transition-colors hover:bg-slate-900/90"
				>
					View Products
				</a>
			</div>
		</div>

		<div class="flex w-full justify-start pt-6">
			<div class="relative inline-flex flex-col">
				<img
					class="absolute left-0 -top-[52px] aspect-square size-[72px] -rotate-[4.672deg] object-contain"
					src="/data/brand/orkait.svg"
					alt="Orkait Logo Fin"
					width="200"
					height="200"
				/>

				<div
					class="text-[clamp(4.5rem,24vw,5.6rem)] font-bold tracking-[-0.05em] text-foreground"
					style="line-height: 0.8;"
				>
					ORKAIT
				</div>

				<div
					class="-scale-y-100 text-[clamp(4.5rem,24vw,5.6rem)] font-bold tracking-[-0.05em] text-foreground/12"
					style="line-height: 0.8; -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent 80%); mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent 100%);"
				>
					ORKAIT
				</div>
			</div>
		</div>
	</div>

	{/* Tablet/laptop view */}
	<div class="relative hidden h-[600px] w-full overflow-visible tablet:block laptop:h-[750px]">
		{/* Tagline */}
		<div class="absolute right-0 z-20 w-full max-w-[450px] tablet:top-6 laptop:top-[12px] laptop:max-w-[1000px]">
			<p class="text-right text-[36px] font-bold leading-tight tracking-[-0.96px] text-black laptop:text-[52px] laptop:leading-[50px]">
				We engineer software that works.
				<br />
				Honest engineering.
				<br />
				Reliable systems.
				<br />
				No hype.
			</p>
		</div>

		{/* Brand group */}
		<div class="absolute left-0 flex items-start tablet:top-[200px] laptop:top-[240px]">
			<div class="relative transition-all duration-500">
				{/* Logo fin */}
				<div class="pointer-events-none absolute z-10 tablet:-top-[95px] tablet:left-[-10px] laptop:-top-[70px] laptop:left-[-10px]">
					<div class="rotate-[-5deg] transition-transform duration-300">
						<img
							class="tablet:h-[180px] tablet:w-[180px] laptop:h-[240px] laptop:w-[240px] object-contain"
							src="/data/brand/orkait.svg"
							alt="Orkait Fin Logo"
							width="240"
							height="240"
						/>
					</div>
				</div>

				{/* "ORKAIT" heading */}
				<div
					class="ml-0 text-[140px] font-bold tracking-normal text-black transition-all duration-300 tablet:mt-[80px] laptop:mt-[110px] laptop:text-[230.4px]"
					style="line-height: 0.76;"
				>
					ORKAIT
				</div>

				{/* Reflection */}
				<div
					class="pointer-events-none ml-0 -scale-y-100 text-[140px] font-bold text-black opacity-30 transition-all duration-300 laptop:text-[230.4px]"
					style="line-height: 0.76; mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, transparent 80%); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, transparent 80%);"
				>
					ORKAIT
				</div>
			</div>
		</div>
	</div>

	{/* Desktop spacer */}
	<div class="hidden h-[64px] tablet:block"></div>
</div>
