---
import Section from "@/components/layout/Section.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";

interface ContentPageLink {
	label: string;
	href: string;
}

interface Props {
	eyebrow: string;
	title: string;
	description: string;
	links?: ContentPageLink[];
}

const { eyebrow, title, description, links = [] } = Astro.props;
---

<SiteHeader />

<main>
	<Section background="default" spacing="lg" class="text-foreground">
		<div class="mx-auto flex w-full max-w-3xl flex-col gap-8">
			<p class="text-body font-medium uppercase leading-body tracking-wide text-muted-foreground">
				{eyebrow}
			</p>
			<h1 class="text-title-1 font-bold leading-title-1 tracking-tight">
				{title}
			</h1>
			<p class="max-w-3xl text-body-lg leading-body-lg text-muted-foreground">
				{description}
			</p>
			{
				links.length > 0 && (
					<div class="flex flex-wrap gap-3">
						{links.map((link) => (
							<a
								href={link.href}
								class="rounded-lg border border-border px-4 py-2 text-body font-medium text-foreground transition-colors hover:bg-secondary"
							>
								{link.label}
							</a>
						))}
					</div>
				)
			}
		</div>
	</Section>
</main>

<SiteFooter />
