---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/layout/Section.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import { ContactForm } from "@/components/react/ContactForm";
import { FOOTER_SOCIAL_LINKS } from "@/lib/data/footer";
---

<Layout
	title="Research Partnerships"
	description="Bring a hard systems problem with a path to a real product or research system."
>
	<SiteHeader />

	<main>
		<Section background="default" spacing="lg" class="text-foreground">
			<div class="flex flex-col gap-12 tablet:flex-row tablet:items-start tablet:gap-16">
				<div class="flex-1">
					<h1 class="text-title-2 font-bold leading-title-2 tracking-tight text-foreground tablet:text-title-1 tablet:leading-title-1">
						Bring a hard<br />
						systems<br />
						problem.
					</h1>

					<div class="mt-12 flex flex-col gap-3 tablet:mt-16">
						<p class="text-body font-medium leading-body text-muted-foreground">
							Or reach the lab through public channels
						</p>
						<div class="flex gap-4">
							{
								FOOTER_SOCIAL_LINKS.map((link) => (
									<a
										href={link.href}
										target="_blank"
										rel="noopener noreferrer"
										class="text-body font-medium leading-body text-foreground underline underline-offset-4 transition-opacity hover:opacity-70"
									>
										{link.label}
									</a>
								))
							}
						</div>
					</div>
				</div>

				<div class="flex-1">
					<ContactForm client:load />
				</div>
			</div>
		</Section>
	</main>

	<SiteFooter />
</Layout>
