---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/layout/Section.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import { parseMarkdownBlocks } from "@/lib/markdown";
import knowledgeMarkdown from "../../chatbot/knowledge/index.md?raw";

const blocks = parseMarkdownBlocks(knowledgeMarkdown);
---

<Layout
	title="Knowledge"
	description="Curated public knowledge base covering Orkait's current public products, infrastructure, and upcoming product lines."
>
	<SiteHeader />

	<main id="main">
		<Section background="default" spacing="lg" class="text-foreground">
			<article class="mx-auto flex max-w-3xl flex-col gap-6">
				{
					blocks.map((block) => {
						if (block.type === "h1") {
							return (
								<h1 class="text-title-2 font-bold leading-title-2 tracking-tight tablet:text-title-1 tablet:leading-title-1">
									{block.text}
								</h1>
							);
						}

						if (block.type === "h2") {
							return (
								<h2 class="pt-8 text-title-3 font-bold leading-title-3 tracking-tight tablet:text-subtitle tablet:leading-subtitle">
									{block.text}
								</h2>
							);
						}

						if (block.type === "h3") {
							return (
								<h3 class="pt-4 text-body-lg font-semibold leading-body-lg">
									{block.text}
								</h3>
							);
						}

						if (block.type === "list") {
							return (
								<ul class="flex list-disc flex-col gap-2 pl-6 text-body leading-body text-muted-foreground">
									{block.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
							);
						}

						return (
							<p class="text-body leading-body text-muted-foreground">
								{block.text}
							</p>
						);
					})
				}
			</article>
		</Section>
	</main>

	<SiteFooter />
</Layout>
