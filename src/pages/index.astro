---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/layout/Section.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import Hero from "@/components/sections/home/Hero.astro";
import StudioText from "@/components/sections/home/StudioText.astro";
import ServicesText from "@/components/sections/home/ServicesText.astro";
import Advance from "@/components/sections/home/Advance.astro";
import Process from "@/components/sections/home/Process.astro";
import Flash from "@/components/react/Flash";
import Feedback from "@/components/react/Feedback";
---

<Layout>
	<SiteHeader />

	<main>
		<Section spacing="none" class="pt-12 tablet:pt-16 laptop:pt-20">
			<Hero />
		</Section>

		<Section spacing="none">
			<Flash client:visible />
		</Section>

		<Section spacing="none">
			<StudioText />
		</Section>

		<Section spacing="none">
			<ServicesText />
		</Section>

		<Section spacing="none">
			<Advance />
		</Section>

		<Section spacing="none">
			<Feedback client:visible />
		</Section>

		<Section spacing="none" class="pb-12 tablet:pb-16 laptop:pb-20">
			<Process />
		</Section>
	</main>

	<SiteFooter />
</Layout>
