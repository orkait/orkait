---
import Layout from "@/layouts/Layout.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import Hero from "@/components/sections/home/Hero.astro";
import Clients from "@/components/sections/home/Clients.astro";
import Bento from "@/components/sections/home/Bento.astro";
import Capabilities from "@/components/sections/home/Capabilities.astro";
import CtaBand from "@/components/sections/home/CtaBand.astro";
---

<Layout chat={false}>
	<SiteHeader overlap />

	<main id="main">
		<Hero />
		<Clients />
		<Bento />
		<Capabilities />
		<CtaBand />
	</main>

	<SiteFooter />
</Layout>
