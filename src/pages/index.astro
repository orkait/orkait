---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/layout/Section.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import { PRODUCT_LINES } from "@/lib/data/products";
import { cn } from "@/lib/utils";
---

<Layout>
	<SiteHeader />

	<main>
		<Section spacing="lg">
			<div class="flex max-w-3xl flex-col gap-6" data-reveal>
				<span class="text-body font-medium uppercase tracking-[0.12em] text-muted-foreground">
					Product-first AI lab
				</span>
				<h1 class="text-title-1 font-medium leading-title-1 tracking-tight tablet:text-heading tablet:leading-heading">
					Applied AI research, shipped as products.
				</h1>
				<p class="text-body-lg leading-body-lg text-muted-foreground">
					Orkait builds focused tools for secure execution, software learning, and
					AI-assisted creation. Rustbox is live. BooleanStack and Zen are coming soon.
				</p>
				<div class="flex flex-wrap gap-3 pt-2">
					<a
						href="https://rustbox.orkait.com"
						class="rounded-lg bg-primary px-5 py-3 text-body font-medium text-primary-foreground transition-opacity hover:opacity-90"
					>
						Open Rustbox
					</a>
					<a
						href="/projects"
						class="rounded-lg border border-border px-5 py-3 text-body font-medium text-foreground transition-colors hover:bg-secondary"
					>
						Products &amp; Team
					</a>
				</div>
			</div>
		</Section>

		<Section background="light" spacing="lg">
			<div class="flex flex-col gap-8">
				<h2 class="text-title-3 font-medium leading-title-3 tracking-tight" data-reveal>
					What we build
				</h2>
				<div class="grid gap-6 tablet:grid-cols-3">
					{
						PRODUCT_LINES.map((product) => (
							<article
								class="flex flex-col gap-4 rounded-xl border border-border bg-background p-6"
								data-reveal
							>
								<div class="flex items-center justify-between">
									<h3 class="text-subtitle font-medium leading-subtitle">{product.title}</h3>
									<span
										class={cn(
											"rounded-full px-3 py-1 text-body font-medium",
											product.status === "live"
												? "bg-success/15 text-success"
												: "bg-muted text-muted-foreground",
										)}
									>
										{product.statusLabel}
									</span>
								</div>
								<p class="text-body font-medium text-muted-foreground">{product.surface}</p>
								<p class="text-body leading-body text-foreground/80">{product.summary}</p>
								{product.href ? (
									<a
										href={product.href}
										class="mt-auto text-body font-medium text-foreground underline-offset-4 hover:underline"
									>
										{product.ctaLabel} &rarr;
									</a>
								) : (
									<span class="mt-auto text-body font-medium text-muted-foreground">
										{product.ctaLabel}
									</span>
								)}
							</article>
						))
					}
				</div>
			</div>
		</Section>
	</main>

	<SiteFooter />
</Layout>
