---
import Layout from "@/layouts/Layout.astro";
import ContentPage from "@/components/shared/ContentPage.astro";
import { routes } from "@/lib/data/nav";
---

<Layout
	title="Privacy Policy"
	description="Review how Orkait collects, stores, and uses information across our products and services."
>
	<ContentPage
		eyebrow="(03) Legal"
		title="Privacy and data handling."
		description="We collect only the information required to provide services and support communication. Data is processed with care, protected with industry best practices, and never sold."
		links={[
			{ label: "Terms & Conditions", href: routes.terms },
			{ label: "Contact", href: routes.contact },
		]}
	/>
</Layout>
