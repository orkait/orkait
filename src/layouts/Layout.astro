---
import "@/styles/global.css";
import { siteConfig } from "@/lib/site";
import ChatWidget from "@/components/react/ChatWidget";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = siteConfig.description,
	image = "/og.png",
} = Astro.props;

const fullTitle = title ? `${title} | ${siteConfig.name}` : `${siteConfig.name} - Applied AI research, shipped as products`;
const canonical = new URL(Astro.url.pathname, siteConfig.url).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="canonical" href={canonical} />

		<link
			rel="preload"
			href="/fonts/Satoshi-Variable.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<title>{fullTitle}</title>
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={new URL(image, siteConfig.url).href} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, siteConfig.url).href} />
	</head>
	<body>
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[1100] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-2 focus:font-medium focus:text-foreground focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-ring"
			>Skip to main content</a
		>
		<slot />

		<ChatWidget client:idle />

		<script>
			import { initSmoothScroll } from "@/lib/client/smoothScroll";
			import { initRevealOnScroll } from "@/lib/client/revealOnScroll";
			initRevealOnScroll();
			initSmoothScroll();
		</script>
	</body>
</html>
